PROJECT_NAME="NAIC Image Classification API"
VERSION="2.0.0"
API_V1_STR="/api/v1"

# CORS origins (comma separated)
# BACKEND_CORS_ORIGINS=["http://localhost:3000","https://your-site.web.app"]

# Model Directories
CONVNEXT_WEIGHTS_DIR="convnext_best_weights"
EFFICIENTNET_WEIGHTS_DIR="efficientnetb3_best_weights"

# Ensemble Strategy Options: simple_avg, weighted_avg, per_class_weighted, rank_fusion
ENSEMBLE_STRATEGY="simple_avg"

# Legacy
WEIGHTS_DIR="weights"
NUM_FOLDS=5
MODEL_PREFIX="best_model_fold_"

DEVICE="cpu"
